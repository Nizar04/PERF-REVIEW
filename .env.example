# ============================================================
# DATABASE (Neon)
# ============================================================
# Pooled connection URL — used by the app at runtime (copy from Neon dashboard → Connection string → Pooled)
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.neon.tech/<dbname>?sslmode=require"
# Direct (non-pooled) URL — used only by Prisma migrations
DIRECT_URL="postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require"

# ============================================================
# NEXTAUTH
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ============================================================
# OAUTH PROVIDERS
# ============================================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
AZURE_AD_CLIENT_ID="your-azure-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-client-secret"
AZURE_AD_TENANT_ID="your-azure-tenant-id"

# ============================================================
# EMAIL (Nodemailer / Resend)
# ============================================================
EMAIL_FROM="noreply@yourcompany.com"
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="your-resend-api-key"

# ============================================================
# STORAGE (Supabase Storage)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="attachments"

# ============================================================
# RATE LIMITING (Upstash Redis)
# ============================================================
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Performance Review"
NODE_ENV="development"
